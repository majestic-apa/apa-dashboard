# Database (Drizzle — not used in mock mode)
DATABASE_URL="postgres://user:password@localhost:5432/dbname"

# Set to true to use mock data instead of calling real FastAPI
# Switch to false (and set VITE_API_URL) when Suleiman's FastAPI is ready
VITE_MOCK_API=true

# FastAPI base URL (only used when VITE_MOCK_API=false)
VITE_API_URL=http://localhost:8000
